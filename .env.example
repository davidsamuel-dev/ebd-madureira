# Copie este arquivo para .env na raiz do projeto e preencha com os dados do Console Firebase:
# Configurações do projeto (ícone de engrenagem) → Seus aplicativos → app da Web (</>)
# Se ainda não tiver app Web, clique em "Adicionar app" → Web.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Opcional — só se você ativou Google Analytics no Firebase
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# E-mail do administrador master (mesmo login do Firebase). Comparação sem diferenciar maiúsculas/minúsculas.
# Professores: qualquer outro usuário criado no Authentication.
EXPO_PUBLIC_ADMIN_EMAIL=
